#: weblate_web/templates/donate.html:250
#: weblate_web/templates/snippets/box-donate.html:10
#: weblate_web/templates/snippets/main-menu.html:19
msgid "Donate"
msgstr "ບໍລິຈາກ"

#: weblate_web/templates/donate.html:75
msgid "Weblate heroism"
msgstr "Weblate heroism"

#: weblate_web/templates/donate.html:77
msgid ""
"Commercial services like hosting or support for self-hosted installations "
"help fund Weblate development."
msgstr ""
"ບໍລິການທາງການຄ້າເຊັ່ນ: ການໂຮສ ຫຼື ການສະໜັບສະໜູນສຳລັບການຕິດຕັ້ງດ້ວຍຕົນເອງ ຊ່ວຍໃຫ້ທຶນແກ່ການພັດທະນາ "
"Weblate."

#: weblate_web/templates/donate.html:80
msgid "Get help from Weblate"
msgstr "ຮັບຄວາມຊ່ວຍເຫຼືອຈາກ Weblate"

#: weblate_web/templates/donate.html:88
msgid "Single appreciative donation"
msgstr "ບໍລິຈາກເພື່ອຄວາມຊື່ນຊົມເທື່ອດຽວ"

#: weblate_web/templates/donate.html:90
msgid ""
"One-time donations are a great way to bring attention to a single issue "
"before or after it is fixed."
msgstr "ການບໍລິຈາກເທື່ອດຽວເປັນວິທີທີ່ດີໃນການດຶງດູດຄວາມສົນໃຈຕໍ່ບັນຫາໃດໜຶ່ງ ກ່ອນ ຫຼື ຫຼັງຈາກທີ່ມັນຖືກແກ້ໄຂ."

#: weblate_web/templates/donate.html:101
msgid "Weblate swag"
msgstr "ຂອງທີ່ລະນຶກ Weblate"

#: weblate_web/templates/donate.html:102
msgid ""
"Buying branded clothing and merch is a great way to support Weblate and show "
"your pride!"
msgstr ""
"ການຊື້ເສື້ອຜ້າ ແລະ ຂອງທີ່ລະນຶກທີ່ມີຍີ່ຫໍ້ ເປັນວິທີທີ່ດີໃນການສະໜັບສະໜູນ Weblate ແລະ "
"ສະແດງຄວາມພາກພູມໃຈຂອງທ່ານ!"

#: weblate_web/templates/donate.html:103
msgid "Shop from Europe"
