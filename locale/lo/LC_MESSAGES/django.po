#: weblate_web/views.py:426
msgid "Thank you for your donation and enjoy FOSDEM."
msgstr "ຂອບໃຈສຳລັບການບໍລິຈາກຂອງເຈົ້າ ແລະ ຂໍໃຫ້ມ່ວນກັບ FOSDEM."

#: weblate_web/views.py:466
msgid ""
"Please provide your name to complete the payment. Include other billing "
"information if you need it on the receipt."
msgstr ""
"ກະລຸນາລະບຸຊື່ຂອງເຈົ້າເພື່ອໃຫ້ການຊຳລະເງິນສຳເລັດ. "
"ລວມຂໍ້ມູນການເອີ້ນເກັບເງິນອື່ນໆຖ້າເຈົ້າຕ້ອງການໃຫ້ມີໃນໃບຮັບເງິນ."

#: weblate_web/views.py:473 weblate_web/views.py:509
msgid "Please provide your billing information to complete the payment."
msgstr "ກະລຸນາລະບຸຂໍ້ມູນການເອີ້ນເກັບເງິນຂອງເຈົ້າເພື່ອໃຫ້ການຊຳລະເງິນສຳເລັດ."

#: weblate_web/views.py:485
msgid "The VAT ID is no longer valid, please update it."
msgstr "VAT ID ບໍ່ຖືກຕ້ອງອີກຕໍ່ໄປ, ກະລຸນາອັບເດດມັນ."

#: weblate_web/views.py:504
msgid "Please choose a payment method."
msgstr "ກະລຸນາເລືອກວິທີການຊຳລະເງິນ."

#: weblate_web/views.py:537
#, python-format
msgid "Could not perform payment: %s"
msgstr "ບໍ່ສາມາດຊຳລະເງິນໄດ້: %s"

#: weblate_web/views.py:547
#, python-format
msgid "Could not complete payment: %s"
msgstr "ບໍ່ສາມາດເຮັດການຊຳລະເງິນໃຫ້ສຳເລັດໄດ້: %s"

#: weblate_web/views.py:604
msgid ""
"Please use already generated agreement, you can generate new one after 30 "
"days."
msgstr "ກະລຸນາໃຊ້ຂໍ້ຕົກລົງທີ່ສ້າງຂຶ້ນແລ້ວ, ເຈົ້າສາມາດສ້າງອັນໃໝ່ໄດ້ຫຼັງຈາກ 30 ມື້."

#: weblate_web/views.py:611
msgid "New agreement created, you can download it below."
msgstr "ສ້າງຂໍ້ຕົກລົງໃໝ່ແລ້ວ, ເຈົ້າສາມາດດາວໂຫຼດມັນໄດ້ດ້ານລຸ່ມນີ້."

#: weblate_web/views.py:667
msgid ""
"New company, new bank details! Pay with attention to the current invoice."
msgstr "ບໍລິສັດໃໝ່, ລາຍລະອຽດທະນາຄານໃໝ່! ຊຳລະເງິນໂດຍເອົາໃຈໃສ່ກັບໃບກຳກັບພາສີປັດຈຸບັນ."

#: weblate_web/views.py:726
msgid "Payment not yet processed, please retry."
msgstr "ການຊຳລະເງິນຍັງບໍ່ຖືກປະມວນຜົນ, ກະລຸນາລອງໃໝ່."

#: weblate_web/views.py:730
msgid "The payment was rejected: {}"
msgstr "ການຊຳລະເງິນຖືກປະຕິເສດ: {}"

#: weblate_web/views.py:731
msgid "Unknown reason"
msgstr "ເຫດຜົນທີ່ບໍ່ຮູ້ຈັກ"

#: weblate_web/views.py:743
msgid ""
"Payment was processed, but the subscription could not be updated. Please "
"contact us."
msgstr "ການຊຳລະເງິນຖືກປະມວນຜົນແລ້ວ, ແຕ່ບໍ່ສາມາດອັບເດດການສະໝັກສະມາຊິກໄດ້. ກະລຸນາຕິດຕໍ່ພວກເຮົາ."

#: weblate_web/views.py:748
msgid "Thank you for your subscription."
msgstr "ຂອບໃຈສຳລັບການສະໝັກສະມາຊິກຂອງເຈົ້າ."

#: weblate_web/views.py:936
msgid ""
"Activate the listing from your Weblate management page using the activation "
"token shown below."
msgstr ""
"ເປີດໃຊ້ງານລາຍການຈາກໜ້າການຈັດການ Weblate ຂອງເຈົ້າໂດຍໃຊ້ລະຫັດເປີດໃຊ້ງານທີ່ສະແດງດ້ານລຸ່ມນີ້."

#: weblate_web/views.py:1123
msgid "User not found!"
msgstr "ບໍ່ພົບຜູ້ໃຊ້!"

#: weblate_web/views.py:1247
msgid "Please confirm the upgrade from your account page."
msgstr "ກະລຸນາຢືນຢັນການອັບເກຣດຈາກໜ້າບັນຊີຂອງເຈົ້າ."
