"Share what is on your mind in the <a href=\"%(url)s\">GitHub discussions</a>."
msgstr ""
"Düşündüklerinizi <a href=\"%(url)s\">GitHub tartışmaları</a> bölümünde "
"paylaşın."

#: weblate_web/templates/contribute.html:95
#: weblate_web/templates/contribute.html:114
msgid "Browse documentation"
msgstr "Belgelere göz at"

#: weblate_web/templates/contribute.html:101
