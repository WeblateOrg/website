msgstr ""
"Bir <strong>özellik</strong> mi eksik ya da bir şeyi değiştirmek mi "
"istiyorsunuz?"

#: weblate_web/templates/contribute.html:74
#, python-format
msgid "Suggest your change in the <a href=\"%(url)s\">GitHub issues</a>."
msgstr ""
"<a href=\"%(url)s\">GitHub sorunları</a> bölümünden değişiklik önerisinde "
"bulunun."

#: weblate_web/templates/contribute.html:84
